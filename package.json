{
  "name": "my-naishin",
  "version": "0.1.0",
  "private": true,
  "browserslist": [
    "> 0.5%",
    "not IE 11"
  ],
  "scripts": {
    "worklog": "node scripts/worklog.mjs",
    "dev": "next dev",
    "build": "NODE_OPTIONS=--max-old-space-size=4096 next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:ci": "jest --ci --coverage",
    "check:links": "node scripts/check-source-links.mjs",
    "check:forbidden": "node scripts/check-forbidden-words.js",
    "check:consistency": "node scripts/check-data-consistency.js",
    "check:orphans": "node scripts/check-orphans.mjs",
    "check:freshness": "node scripts/check-freshness.mjs",
    "report:links": "npx tsx scripts/link-graph-report.ts",
    "check:all": "npm run check:consistency && npm run check:forbidden",
    "monitor:links": "npx tsx src/scripts/link-monitor.ts",
    "newsletter": "npx tsx scripts/newsletter.ts",
    "sales-report": "npx tsx scripts/generate-sales-report.ts",
    "media-kit": "npx tsx scripts/generate-media-kit.ts",
    "kpi:weekly": "npx tsx scripts/weekly-kpi-report.ts",
    "ev:reconcile": "npx tsx scripts/reconcile-affiliate-economics.ts",
    "push-send": "npx tsx scripts/push-send.ts",
    "ga4:auth": "node --use-system-ca scripts/ga4-auth.mjs",
    "ga4": "node --use-system-ca scripts/ga4.mjs",
    "ga4:mcp": "node --use-system-ca scripts/ga4-mcp.mjs",
    "ga4:weekly": "node --use-system-ca scripts/ga4-weekly.mjs",
    "test:e2e": "playwright test",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "gsc:auth": "node --use-system-ca scripts/gsc-auth.mjs",
    "gsc:mcp": "node --use-system-ca scripts/gsc-mcp.mjs",
    "gsc": "node --use-system-ca scripts/gsc.mjs"
  },
  "dependencies": {
    "@googleapis/searchconsole": "^6.0.1",
    "@opennextjs/cloudflare": "^1.16.5",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/qrcode": "^1.5.6",
    "canvas-confetti": "^1.9.3",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.469.0",
    "next": "^15.5.14",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.4",
    "tailwind-merge": "^2.6.1"
  },
  "devDependencies": {
    "@googleapis/analyticsadmin": "^17.0.0",
    "@googleapis/analyticsdata": "^5.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.49.0",
    "@types/babel__core": "^7.20.5",
    "@types/canvas-confetti": "^1.6.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.37",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.14",
    "google-auth-library": "^10.7.0",
    "googleapis": "^173.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.59.2"
  }
}
